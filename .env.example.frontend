# Frontend Environment Variables
# Copy these to your .env file for frontend configuration

# API Base URL - The base URL for the Laravel backend API
# For local development, this typically points to your Laravel server
VITE_API_BASE_URL=http://localhost:8000/api

# App Name - Used for page titles and branding
VITE_APP_NAME=Desaku

# App Environment - Used for environment-specific behavior
VITE_APP_ENV=local
